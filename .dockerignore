# =============================================================================
# ZOE — .dockerignore
# Excluye archivos innecesarios de la imagen Docker de producción
# =============================================================================

# -----------------------------------------------------------------------------
# Control de versiones
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Caché de Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# -----------------------------------------------------------------------------
# Entornos virtuales
# -----------------------------------------------------------------------------
.env
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Datos y bases de datos locales (no incluir en imagen)
# -----------------------------------------------------------------------------
zoe_data/
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Tests (no necesarios en producción)
# -----------------------------------------------------------------------------
tests/
test/
*_test.py
pytest.ini
.pytest_cache/
.coverage
htmlcov/
tox.ini

# -----------------------------------------------------------------------------
# Documentación (opcional para producción)
# -----------------------------------------------------------------------------
docs/
*.md
!README.md

# -----------------------------------------------------------------------------
# Artefactos de build y distribución
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# Configuraciones de IDEs y editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# CI/CD y herramientas de desarrollo
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
.pre-commit-config.yaml
Makefile
docker-compose*.yml
Dockerfile*

# -----------------------------------------------------------------------------
# Otros
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
scripts/
examples/
