# ============================================================================
# ZOE Kubernetes Secrets — TEMPLATE
# ============================================================================
# Copy this file to secret.yaml and fill in real values:
#   cp k8s/secret.yaml.example k8s/secret.yaml
#   $EDITOR k8s/secret.yaml
#
# IMPORTANT: secret.yaml is gitignored and MUST NEVER be committed.
# In production, prefer External Secrets Operator with AWS Secrets Manager,
# Azure Key Vault, or HashiCorp Vault.
# ============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: zoe-secrets
  namespace: zoe
  labels:
    app.kubernetes.io/name: zoe
    app.kubernetes.io/component: secrets
type: Opaque
stringData:
  # PostgreSQL - MANDATORY to change in production
  POSTGRES_PASSWORD: "REPLACE_WITH_STRONG_PASSWORD"

  # API Keys - Uncomment and configure as needed
  # OPENAI_API_KEY: ""
  # TELEGRAM_BOT_TOKEN: ""
  # ANTHROPIC_API_KEY: ""
  # DEEPSEEK_API_KEY: ""

  # JWT / Encryption secrets
  # ZOE_JWT_SECRET: ""
  # ZOE_ENCRYPTION_KEY: ""

---
# RECOMMENDED for production: External Secrets Operator
# https://external-secrets.io/latest/
